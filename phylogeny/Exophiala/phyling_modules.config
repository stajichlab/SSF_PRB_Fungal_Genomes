// Site override for nf_phyling on UCR HPCC.
// Pins environment-module versions so the correct binaries load.
// Applied last via `-c`, so these beforeScript settings override the
// bare `module load <tool>` from the `slurm` profile.
//
// Notably the pipeline calls the `iqtree3` binary, which only ships in
// iqtree/3.0.1 (the default `module load iqtree` does NOT provide it).

process {
    withName: 'PHYLING_ALIGN|PHYLING_FILTER|PHYLING_TREE' {
        beforeScript = 'module load phyling/2.3.1'
    }
    withName: 'PHYKIT_CONCAT' {
        beforeScript = 'module load phykit/1.11'
    }
    withName: 'MODELTEST_NG' {
        beforeScript = 'module load modeltest-ng/0.1.7'
    }
    withName: 'IQTREE_MF|IQTREE_BOOTSTRAP' {
        beforeScript = 'module load iqtree/3.0.1'
    }
    withName: 'RAXMLNG_PARSE|RAXMLNG_ALL' {
        beforeScript = 'module load raxml-ng/1.2.0'
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_timeline.html"
    overwrite = true
}
